{
  "name": "@nodestrap/control",
  "version": "2.0.25",
  "description": "A base class providing a basic manipulation of controllable HTML element such as <button>, <input>, and <textarea>.",
  "dependencies": {
    "@nodestrap/colors": "^2.0.1",
    "@nodestrap/element": "^2.0.24",
    "@nodestrap/sass-class-template": "^2.0.2",
    "@nodestrap/sass-selector": "^2.0.1",
    "@nodestrap/strip-out": "^2.0.0",
    "react": "^17.0.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^5.11.9",
    "@testing-library/react": "^11.2.3",
    "@testing-library/user-event": "^12.6.2",
    "@types/jest": "^26.0.20",
    "@types/node": "^14.14.22",
    "@types/react": "^17.0.0",
    "@types/react-dom": "^17.0.0",
    "react-dom": "^17.0.1",
    "react-scripts": "^4.0.1",
    "tilde-sass": "^1.0.0",
    "typescript": "^4.1.3"
  },
  "scripts": {
    "test": "react-scripts test",
    "testsass": "tilde-sass --file src/*.scss --outFile test/",
    "compile": "tilde-sass --file src/*.scss --outFile dist/ --outputStyle compressed"
  },
  "jest": {
    "transformIgnorePatterns": [
      "[/\\\\]node_modules[/\\\\](?!@nodestrap[/\\\\].+[/\\\\](dist|src)[/\\\\](.+[/\\\\])*).+[.](js|mjs|jsx|ts|tsx|cjs)$",
      "^.+[.]module[.](css|sass|scss)$"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nodestrap/control.git"
  },
  "keywords": [
    "html",
    "element",
    "dom",
    "control",
    "input",
    "manipulation"
  ],
  "author": "nodestrap, heymarco",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/nodestrap/control/issues"
  },
  "homepage": "https://github.com/nodestrap/control#readme"
}
